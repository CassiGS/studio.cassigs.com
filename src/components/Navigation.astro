---
import { NAV_LINKS, SITE } from "../siteConfig.ts";
---

<header>
  <a href="/" class="site-title">{SITE.title}</a>
  <nav>
    <ul class="nav-list">
      {
        Object.values(NAV_LINKS).map((navItem) => {
          return (
            <li>
              <a href={navItem.path} class="link">
                {navItem.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

<style>
  header {
    margin-left: auto;
    margin-right: auto;
    max-width: 640px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem;
    padding-bottom: 2rem;
  }
  @media (min-width: 640px) {
    header {
      padding: 1.5rem;
    }
  }
  .site-title {
    font-size: 1.125rem;
    line-height: 1.75rem;
    font-weight: 600;
    color: #000;
    text-decoration: none;
  }
  @media (min-width: 640px) {
    .site-title {
      font-size: 1.25rem;
    }
  }
  :global(.dark) .site-title {
    color: #fff;
  }
  .nav-list {
    display: flex;
    list-style: none;
    align-items: center;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
  }
  @media (min-width: 640px) {
    .nav-list {
      gap: 0.75rem;
    }
  }
</style>
