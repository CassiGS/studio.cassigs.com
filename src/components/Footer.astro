---
import { SITE } from "../siteConfig";
import ThemeToggle from "./ThemeToggle.astro";

const year = new Date().getFullYear();
---

<footer>
  <ThemeToggle />
  <span class="prose dark:prose-invert prose-neutral footer-year"
    >{year} {SITE.author}</span
  >
</footer>

<style>
  footer {
    margin-left: auto;
    margin-right: auto;
    display: flex;
    width: 100%;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    padding-top: 4rem;
    padding-bottom: 6rem;
  }
  @media (min-width: 640px) {
    footer {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
    }
  }
  .footer-year {
    margin-top: 0.5rem;
  }
</style>
