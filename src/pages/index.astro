---
import '../styles/global.css'
import styles from './index.module.css'

const mockPosts = [
  {
    title: 'On the anatomy of a good diagram',
    date: '2026-03-10',
    type: 'process-note',
    description: 'A close reading of how scientific illustration handles information density — and what data visualisation can borrow from the tradition.',
  },
  {
    title: 'Field notes: mapping growth rings',
    date: '2026-02-24',
    type: 'sketchbook',
    description: 'Early sketches from a project encoding tree ring data. Exploring radial layouts, line weight as time, and the tension between legibility and accumulation.',
  },
  {
    title: 'Why I stopped using rounded corners',
    date: '2026-02-08',
    type: 'thinking',
    description: 'A short argument for precision over softness in interface design, and what a commitment to sharp edges forces you to resolve elsewhere.',
  },
  {
    title: 'Specimen index: colour systems in cartography',
    date: '2026-01-19',
    type: 'data-viz',
    description: 'An annotated survey of historical cartographic colour conventions — how hue, saturation, and value carried semantic load before the legend became standard.',
  },
]
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Studio — Cassigs</title>
  </head>
  <body>
    <main class={styles.page}>
      <div class={styles.grid}>

        <!-- Left: blog feed -->
        <section>
          <p class={styles.feedHeader}>Recent writing</p>
          <div class={styles.feed}>
            {mockPosts.map((post) => (
              <article class={styles.postCard}>
                <div class={styles.postMeta}>
                  <span class={styles.postType}>{post.type}</span>
                  <span class={styles.postDate}>{post.date}</span>
                </div>
                <h2 class={styles.postTitle}>{post.title}</h2>
                <p class={styles.postDescription}>{post.description}</p>
              </article>
            ))}
          </div>
        </section>

        <!-- Right: sidebar -->
        <aside class={styles.sidebar}>
          <div class={styles.aboutSection}>
            <p class={styles.aboutHeader}>About the Studio</p>
            <p class={styles.aboutText}>
              A working studio for research, illustration, and data visualisation.
              The focus is on making complex information precise and readable —
              drawing from the conventions of scientific illustration, cartography,
              and the field notebook.
            </p>
            <p class={styles.aboutText}>
              Projects span print, screen, and the space between — typographic
              systems, annotated datasets, and visual essays on structure and form.
            </p>
          </div>
        </aside>

      </div>
    </main>
  </body>
</html>
