---
import BaseLayout from "../layouts/BaseLayout.astro";

import SeoPage from "../components/SeoPage.astro";
---

<BaseLayout>
  <SeoPage slot="head" title="404: Page Not Found" />
  <div class="not-found">
    <h2 class="not-found-heading">404: Page Not Found</h2>
    <p class="not-found-text">
      Whatever you're looking for doesn't appear to be available. Sorry.
    </p>
  </div>
</BaseLayout>

<style>
  .not-found {
    margin-top: 4rem;
    text-align: center;
  }
  .not-found-heading {
    margin-bottom: 0.75rem;
    font-size: 2.25rem;
    line-height: 2.5rem;
    font-weight: 700;
    text-wrap: balance;
  }
  .not-found-text {
    text-wrap: balance;
  }
</style>
